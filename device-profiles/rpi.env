# ─────────────────────────────────────────
# Device Profile: Raspberry Pi Zero 2W (Broadcom BCM43438)
# NOTE: Only 2.4GHz supports, 5GHz is not supported by this device.
# ─────────────────────────────────────────
DEVICE_TYPE=rpi
P2P_IFACE=wlan0
SUPPORTS_5GHZ=false
UBOOT_ENV_SUPPORT=false

# 2.4GHz parameters
P2P_CHANNEL=6
P2P_FREQ=2437
P2P_REG_CLASS=81

# 5GHz not supported, but we can set default values for completeness
P2P_CHANNEL_24=6
P2P_FREQ_24=2437
P2P_REG_CLASS_24=81