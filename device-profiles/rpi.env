# ─────────────────────────────────────────
# Device Profile: Raspberry Pi Zero / Zero 2W (BCM43438)
# Only 2.4GHz supported
# ─────────────────────────────────────────
DEVICE_TYPE=rpi
P2P_IFACE=wlan0
SUPPORTS_5GHZ=false
UBOOT_ENV_SUPPORT=false

# 2.4GHz only
P2P_CHANNEL=6
P2P_FREQ=2437
P2P_REG_CLASS=81

P2P_CHANNEL_24=6
P2P_FREQ_24=2437
P2P_REG_CLASS_24=81
