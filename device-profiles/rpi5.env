# ─────────────────────────────────────────
# Device Profile: Raspberry Pi 5 (CYW43455)
# 5GHz supported
# ─────────────────────────────────────────
DEVICE_TYPE=rpi5
P2P_IFACE=wlan0
SUPPORTS_5GHZ=true
UBOOT_ENV_SUPPORT=false

# 5GHz (default)
P2P_CHANNEL=44
P2P_FREQ=5220
P2P_REG_CLASS=115

# 2.4GHz (fallback)
P2P_CHANNEL_24=6
P2P_FREQ_24=2437
P2P_REG_CLASS_24=81
