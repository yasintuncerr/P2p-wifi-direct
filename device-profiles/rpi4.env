# ─────────────────────────────────────────
# Device Profile: Raspberry Pi 4B (BCM43455)
# 5GHz supported
# ─────────────────────────────────────────
DEVICE_TYPE=rpi4
P2P_IFACE=wlan0
SUPPORTS_5GHZ=true
UBOOT_ENV_SUPPORT=false

# 5GHz parameters (default)
P2P_CHANNEL=44
P2P_FREQ=5220
P2P_REG_CLASS=115

# 2.4GHz parameters (fallback)
P2P_CHANNEL_24=6
P2P_FREQ_24=2437
P2P_REG_CLASS_24=81
