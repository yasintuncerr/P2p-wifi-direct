[Unit]
Description=P2P Wi-Fi Direct - Connection Watchdog
After=p2p-init.service
Wants=p2p-init.service
PartOf=p2p-init.service

[Service]
Type=simple
EnvironmentFile=/etc/default/video-node
ExecStart=/usr/bin/p2p-watchdog
Restart=always
RestartSec=3

StandardOutput=journal
StandardError=journal
SyslogIdentifier=p2p-watchdog

[Install]
WantedBy=multi-user.target
